# source://puffing-billy//lib/billy/handlers/handler.rb#2
module Billy::Handler
  # Handles an incoming HTTP request and returns a response.
  #
  # This method accepts HTTP request parameters and must return
  # a response hash containing the keys :status, :headers,
  # and :content, or nil if the request cannot be fulfilled.
  #
  # @param body [String] The body of the HTTP request.
  # @param headers [String] The headers of the HTTP request.
  # @param http_method [String] The HTTP method used, e.g. 'http' or 'https'
  # @param url [String] The URL requested.
  # @return [Hash] A hash with the keys [:status, :headers, :content]
  #   Returns {:error => "Some error message"} if a failure occurs.
  #   Returns nil if the request cannot be fulfilled.
  #
  # source://puffing-billy//lib/billy/handlers/handler.rb#18
  def handle_request(_http_method, _url, _headers, _body); end

  # Checks if the Handler can respond to the given request.
  #
  # @param body [String] The body of the HTTP request.
  # @param headers [String] The headers of the HTTP request.
  # @param http_method [String] The HTTP method used, e.g. 'http' or 'https'
  # @param url [String] The URL requested.
  # @return [Boolean] True if the Handler can respond to the request, else false.
  #
  # source://puffing-billy//lib/billy/handlers/handler.rb#32
  def handles_request?(_http_method, _url, _headers, _body); end

  # Resets the Handler to the default/new state
  #
  # This allows the handler to be set back to its default state
  # at the end of tests or whenever else necessary.
  #
  # source://puffing-billy//lib/billy/handlers/handler.rb#43
  def reset; end
end

# source://puffing-billy//lib/billy/json_utils.rb#4
module Billy::JSONUtils
  class << self
    # @return [Boolean]
    #
    # source://puffing-billy//lib/billy/json_utils.rb#5
    def json?(value); end

    # Recursively sorts the key/value pairs of all hashes within the given
    #   data structure while preserving the order of arrays.
    #
    # source://puffing-billy//lib/billy/json_utils.rb#13
    def sort_hash_keys(data); end

    # Recursively sorts the name/value pairs of JSON objects. For instance,
    #   sort_json('{"b" : "2", "a" : "1"}') == sort_json('{"a" : "1", "b" : "2"}')
    #   Per http://json.org/, "An object is an unordered set of name/value pairs"
    #   and "An array is an ordered collection of values". So, we can sort the
    #   name/value pairs by name (key), but we must preserve the order of an array.
    #   Processing JSON in this way enables a consistent SHA to be derived from
    #   JSON payloads which have the same name/value pairs, but different orders.
    #
    # source://puffing-billy//lib/billy/json_utils.rb#34
    def sort_json(json_str); end
  end
end

