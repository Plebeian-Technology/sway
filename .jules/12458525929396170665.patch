+++ b/app/jobs/sway_registration_job.rb
@@ -0,0 +1,25 @@
+# frozen_string_literal: true
+# typed: true
+
+class SwayRegistrationJob < ApplicationJob
+  queue_as :default
+
+  extend T::Sig
+
+  sig { params(user_id: Integer, address_id: Integer, sway_locale_id: Integer, invited_by_id: T.nilable(Integer)).void }
+  def perform(user_id:, address_id:, sway_locale_id:, invited_by_id: nil)
+    user = User.find_by(id: user_id)
+    address = Address.find_by(id: address_id)
+    sway_locale = SwayLocale.find_by(id: sway_locale_id)
+
+    return unless user && address && sway_locale
+
+    SwayRegistrationService.new(
+      user,
+      address,
+      sway_locale,
+      invited_by_id: invited_by_id,
+      async: false
+    ).run
+  end
+end
