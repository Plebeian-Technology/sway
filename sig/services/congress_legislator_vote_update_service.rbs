# Creates LegislatorVotes for Congressional Legislators when a new Bill is created in the Congress sway locale.
class CongressLegislatorVoteUpdateService
    @bill: Bill

    @legislators: untyped

    CONGRESS: 119

    def initialize: (Integer bill_id) -> void

    def run: -> nil

    private

    def senate: -> nil

    def house: -> nil

    def create: (Integer? legislator_id, untyped vote) -> LegislatorVote?

    def representative: (untyped vote) -> Integer?

    def senator: (untyped vote) -> Integer?
end
